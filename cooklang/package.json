{
	"type": "module",
	"name": "cooklang",
	"private": true,
	"exports": {
		".": "./dist/src/index.js",
		"./wasm": "./dist/wasm/cooklang_wasm.cjs"
	},
	"imports": {
		"#wasm": "./dist/wasm/cooklang_wasm.cjs"
	},
	"engines": {
		"node": "^24.15.0 || ^26.0.0"
	},
	"scripts": {
		"build": "pnpm clean && pnpm build:wasm && tsc",
		"build:wasm": "wasm-pack build --release --no-pack --target nodejs --out-dir dist/wasm && pnpm postbuild:wasm",
		"postbuild:wasm": "node scripts/postbuild-wasm.ts",
		"clean": "rimraf dist",
		"fmt": "cargo fmt && eslint --fix",
		"test": "vitest run"
	},
	"license": "MIT",
	"devDependencies": {
		"@lusc/eslint-config": "^17.0.0",
		"@lusc/tsconfig": "^7.2.1",
		"@types/node": "^24.13.3",
		"eslint": "^10.6.0",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10",
		"wasm-pack": "^0.15.0"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
